/**
 * Cloudflare Workers 部署配置
 *
 * 生产: yarn deploy
 * 测试: yarn deploy:test  (--env test → velora-web-test)
 *
 * Cloudflare Workers Builds 测试环境请设置：
 *   构建命令: npm run cf:build:test
 *   部署环境: test（或 development，二者等价）
 *   构建变量: 见 package.json build:test
 *
 * 自定义域名 velora-test.aipassly.com 在 Cloudflare 控制台绑定到 velora-web-test
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "velora-web",
	"main": ".open-next/worker.js",
	"compatibility_date": "2026-05-24",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": ".open-next/assets"
	},
	"images": {
		"binding": "IMAGES"
	},
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "velora-web"
		}
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"vars": {
		"NEXT_PUBLIC_APP_ENV": "production",
		"NEXT_PUBLIC_API_WS_URL": "wss://velora-api-test.aipassly.com/ws/market",
		"NEXT_PUBLIC_EVENTS_WS_URL": "wss://velora-api-test.aipassly.com/ws/events",
		"API_PROXY_TARGET": "https://velora-api-test.aipassly.com"
	},
	"env": {
		"test": {
			"name": "velora-web-test",
			"assets": {
				"binding": "ASSETS",
				"directory": ".open-next/assets"
			},
			"images": {
				"binding": "IMAGES"
			},
			"observability": {
				"enabled": true
			},
			"vars": {
				"NEXT_PUBLIC_APP_ENV": "test",
				"NEXT_PUBLIC_API_WS_URL": "wss://velora-api-test.aipassly.com/ws/market",
				"NEXT_PUBLIC_EVENTS_WS_URL": "wss://velora-api-test.aipassly.com/ws/events",
				"API_PROXY_TARGET": "https://velora-api-test.aipassly.com"
			},
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "velora-web-test"
				}
			]
		},
		"development": {
			"name": "velora-web-test",
			"assets": {
				"binding": "ASSETS",
				"directory": ".open-next/assets"
			},
			"images": {
				"binding": "IMAGES"
			},
			"observability": {
				"enabled": true
			},
			"vars": {
				"NEXT_PUBLIC_APP_ENV": "test",
				"NEXT_PUBLIC_API_WS_URL": "wss://velora-api-test.aipassly.com/ws/market",
				"NEXT_PUBLIC_EVENTS_WS_URL": "wss://velora-api-test.aipassly.com/ws/events",
				"API_PROXY_TARGET": "https://velora-api-test.aipassly.com"
			},
			"services": [
				{
					"binding": "WORKER_SELF_REFERENCE",
					"service": "velora-web-test"
				}
			]
		}
	}
}
